---
import { SITE } from '../lib/site';
---

<section class="newsletter" id="newsletter-form">
  <p class="eyebrow mono">Newsletter Subscription</p>
  <h2>월간 노트 구독</h2>
  <p class="muted desc">
    문제의식, 도구, 런타임, 작업 방식을 매달 정리해 보냅니다.<br />
    서버 없이 mailto로 연결됩니다.
  </p>
  <form class="newsletter-form" onsubmit="return false;">
    <label>
      <span class="mono label-text">이메일</span>
      <input
        type="email"
        placeholder="you@example.com"
        aria-label="이메일 주소"
        class="newsletter-input"
      />
    </label>
    <a
      class="btn"
      href={`mailto:${SITE.contactEmail}?subject=노이즈%20뉴스레터%20구독%20요청`}
    >
      구독 요청 →
    </a>
  </form>
  <div class="nl-links">
    <a class="mono nl-link" href="/newsletter">아카이브 보기 →</a>
    <a class="mono nl-link" href={`mailto:${SITE.contactEmail}?subject=노이즈%20뉴스레터%20구독%20요청`}>
      메일로 구독 →
    </a>
  </div>
</section>

<style>
  .newsletter {
    padding: 1.2rem 1.2rem 1.1rem;
    background: transparent;
    display: grid;
    gap: 0.55rem;
  }

  .newsletter h2 {
    margin: 0.2rem 0 0.1rem;
    font-size: 1.4rem;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .desc {
    font-size: var(--text-sm);
    line-height: 1.62;
    margin: 0;
  }

  .newsletter-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
    margin-top: 0.35rem;
    align-items: end;
  }

  label {
    display: grid;
    gap: 0.3rem;
  }

  .label-text {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .newsletter-input {
    width: 100%;
    border: 1px solid var(--line-strong);
    border-radius: 0;
    padding: 0.52rem 0.7rem;
    font: inherit;
    font-size: var(--text-sm);
    background: var(--surface-strong);
    color: var(--text);
  }

  .newsletter-input:focus {
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }

  .nl-links {
    display: flex;
    gap: 1rem;
    font-size: var(--text-2xs);
    color: var(--muted);
    letter-spacing: 0.06em;
    padding-top: 0.2rem;
  }

  .nl-link {
    text-decoration: none;
  }

  .nl-link:hover {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .newsletter-form {
      grid-template-columns: 1fr;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
