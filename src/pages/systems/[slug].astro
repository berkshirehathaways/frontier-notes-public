---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteLayout from '../../layouts/NoteLayout.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { getAllPublishedNotes, getPublishedCollection } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getPublishedCollection('systems');
  return entries.map((entry) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
if (!slug) throw new Error('Missing slug');

const entry = await getEntry('systems', slug);
if (!entry) throw new Error('System note not found');

const { Content } = await render(entry);
const allNotes = await getAllPublishedNotes();
const related = allNotes
  .filter((item) => item.id !== entry.id)
  .filter(
    (item) =>
      item.data.issue === entry.data.issue ||
      item.data.related_people.some((person) => entry.data.related_people.includes(person)) ||
      item.data.related_tools.some((tool) => entry.data.related_tools.includes(tool)),
  )
  .slice(0, 3);
---

<BaseLayout title={entry.data.title} description={entry.data.subtitle}>
  <NoteLayout entry={entry} related={related}>
    <Content />
  </NoteLayout>
  <div id="newsletter">
    <NewsletterBlock />
  </div>
</BaseLayout>
