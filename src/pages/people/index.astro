---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveNoteRef } from '../../lib/content';

const people = await getCollection('people');
const isDefined = <T,>(value: T | undefined): value is T => Boolean(value);

const peopleWithNotes = await Promise.all(
  people.map(async (person) => ({
    person,
    notes: (await Promise.all(person.data.relatedNotes.map((note) => resolveNoteRef(note)))).filter(isDefined),
  })),
);
---

<BaseLayout title="사람들" description="노이즈가 인터뷰한 AI 네이티브 창업가와 빌더의 프로필과 작업 신호를 모읍니다.">

  <div class="page-head">
    <p class="eyebrow mono">People · {peopleWithNotes.length} entries</p>
    <h1>사람들</h1>
    <p class="muted page-desc">노이즈가 인터뷰한 AI 네이티브 창업가와 빌더의 프로필과 작업 신호를 모읍니다.</p>
  </div>

  <div class="index-grid">
    {peopleWithNotes.map(({ person, notes }) => (
      <article class="index-entry">
        <div class="entry-header">
          <div class="entry-fields">
            <p class="index-field">
              <span class="field-key">name:</span>
              <strong class="field-val">{person.data.name}</strong>
            </p>
            <p class="index-field">
              <span class="field-key">stage:</span>
              <span>{person.data.stage ?? 'n/a'}</span>
            </p>
            <p class="index-field">
              <span class="field-key">role:</span>
              <span>{person.data.role}</span>
            </p>
          </div>
          <span class="tag mono">{person.data.slug}</span>
        </div>

        {person.data.summary && (
          <p class="entry-summary">{person.data.summary}</p>
        )}

        <div class="entry-meta-grid">
          <div class="meta-col">
            <p class="meta-label mono">tools</p>
            <div class="tag-list">
              {person.data.tools.length
                ? person.data.tools.map((t) => <span class="tag">{t}</span>)
                : <span class="na-text">n/a</span>}
            </div>
          </div>
          <div class="meta-col">
            <p class="meta-label mono">signals</p>
            <div class="tag-list">
              {person.data.signals.length
                ? person.data.signals.map((s) => <span class="tag">{s}</span>)
                : <span class="na-text">n/a</span>}
            </div>
          </div>
        </div>

        {notes.length > 0 && (
          <div class="entry-notes">
            <p class="meta-label mono">related notes</p>
            <ul class="related-ul">
              {notes.map((note) => (
                <li>
                  <span class="eyebrow">[{note.data.type.toUpperCase().replace('-',' ')}]</span>
                  <a href={`/${note.collection}/${note.id}`}>{note.data.title}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </article>
    ))}
  </div>

</BaseLayout>

<style>
  .page-head {
    padding: 1.4rem 0 1.1rem;
    border-top: 2px solid var(--text);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.4rem;
  }

  .page-head h1 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .page-desc {
    font-size: var(--text-sm);
    max-width: 60ch;
    line-height: 1.6;
    margin: 0;
  }

  .entry-count {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--faint);
    margin: 0;
  }

  /* 인덱스 그리드 */
  .index-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
  }

  .index-entry {
    padding: 1.1rem 1rem 1.1rem 0;
    border-top: 1px solid var(--line-strong);
    display: grid;
    gap: 0.65rem;
  }

  .index-entry:nth-child(even) {
    padding-left: 1rem;
    padding-right: 0;
    border-left: 1px solid var(--line);
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .entry-fields {
    display: grid;
    gap: 0.18rem;
  }

  .index-field {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    line-height: 1.5;
    margin: 0;
    color: var(--text);
  }

  .field-key {
    color: var(--faint);
    margin-right: 0.3em;
  }

  .field-val {
    font-weight: 700;
  }

  .entry-summary {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .entry-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }

  .meta-col {
    display: grid;
    gap: 0.3rem;
  }

  .meta-label {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--faint);
    margin: 0;
  }

  .na-text {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--faint);
  }

  .entry-notes {
    display: grid;
    gap: 0.35rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--line);
  }

  .related-ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }

  .related-ul li {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: var(--text-sm);
  }

  .related-ul a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.14rem;
    text-decoration-color: var(--line);
  }

  .related-ul a:hover {
    text-decoration-color: var(--text);
  }

  @media (max-width: 900px) {
    .index-grid {
      grid-template-columns: 1fr;
    }

    .index-entry:nth-child(even) {
      padding-left: 0;
      border-left: none;
    }

    .entry-meta-grid {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
  }
</style>
