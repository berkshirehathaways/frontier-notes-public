---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getPublishedCollection } from '../../lib/content';

const notes = await getPublishedCollection('field-notes');
---

<BaseLayout title="현장 노트" description="AI 창업자를 만난 행사, 해커톤, 커뮤니티의 짧은 관찰 기록입니다.">

  <div class="page-head">
    <p class="eyebrow mono">Field Notes · {notes.length} notes</p>
    <h1>현장 노트</h1>
    <p class="muted page-desc">AI 창업자를 만난 행사, 해커톤, 커뮤니티의 짧은 관찰 기록입니다.</p>
  </div>

  <div class="field-list">
    {notes.map((entry) => (
      <ContentCard entry={entry} variant="compact" />
    ))}
  </div>

</BaseLayout>

<style>
  .page-head {
    padding: 1.4rem 0 1.1rem;
    border-top: 2px solid var(--text);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.4rem;
  }

  .page-head h1 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .page-desc {
    font-size: var(--text-sm);
    max-width: 60ch;
    line-height: 1.6;
    margin: 0;
  }

  .field-list .editorial-entry:first-child {
    border-top: 1px solid var(--line-strong);
  }
</style>
