---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import NotesFilter from '../../components/NotesFilter.astro';
import { getAllPublishedNotes } from '../../lib/content';

const notes = await getAllPublishedNotes();
const themes = [...new Set(notes.flatMap((note) => note.data.themes))].sort((a, b) => a.localeCompare(b));
const tools = [...new Set(notes.flatMap((note) => note.data.tools))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Notes" description="type/theme/tool 필터로 노이즈 전체 아카이브를 탐색합니다.">

  <div class="page-head">
    <p class="eyebrow mono">Notes Explorer · {notes.length} total</p>
    <h1>Notes</h1>
    <p class="muted page-desc">type, theme, tool 기반 필터로 전체 아카이브를 탐색합니다.</p>
  </div>

  <NotesFilter themes={themes} tools={tools} />

  <div class="notes-list">
    {notes.map((entry) => (
      <ContentCard entry={entry} variant="compact" showCollection />
    ))}
  </div>

</BaseLayout>

<style>
  .page-head {
    padding: 1.4rem 0 1.1rem;
    border-top: 2px solid var(--text);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.4rem;
  }

  .page-head h1 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .page-desc {
    font-size: var(--text-sm);
    max-width: 60ch;
    line-height: 1.6;
    margin: 0;
  }

  .notes-list .editorial-entry:first-child {
    border-top: 1px solid var(--line-strong);
  }
</style>
