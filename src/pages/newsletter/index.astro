---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { formatDate, getPublishedNewsletters } from '../../lib/content';

const newsletters = await getPublishedNewsletters();
const featured = newsletters.find((entry) => entry.data.featured) ?? newsletters[0];
const rest = featured ? newsletters.filter((n) => n.id !== featured.id) : newsletters;
---

<BaseLayout title="Newsletter" description="월간 구독 노트와 브리핑 아카이브를 확인할 수 있습니다.">

  <div class="page-head">
    <p class="eyebrow mono">Newsletter Archive · {newsletters.length} dispatches</p>
    <h1>뉴스레터 아카이브</h1>
    <p class="muted page-desc">AI native generation의 현장 신호를 매달 엮어 보냅니다.</p>
  </div>

  <!-- 피처드 발행 -->
  {featured && (
    <section class="featured-dispatch">
      <div class="dispatch-eyebrow">
        <span class="eyebrow">[NEWSLETTER]</span>
        <span class="eyebrow">{formatDate(featured.data.date)}</span>
        <span class="featured-badge mono">Featured</span>
      </div>
      <h2 class="dispatch-title">
        <a href={`/newsletter/${featured.id}`}>{featured.data.title}</a>
      </h2>
      <p class="dispatch-subtitle">{featured.data.subtitle}</p>
      <p class="dispatch-summary muted">{featured.data.summary}</p>
      <div class="dispatch-footer">
        <div class="tag-list">
          {featured.data.topics.map((topic) => (
            <span class="tag">{topic}</span>
          ))}
        </div>
        <a href={`/newsletter/${featured.id}`} class="mono dispatch-read">읽기 →</a>
      </div>
    </section>
  )}

  <!-- 아카이브 목록 -->
  {rest.length > 0 && (
    <section class="archive-section">
      <div class="section-title">
        <h2>Archive</h2>
      </div>
      <div class="archive-list">
        {rest.map((entry) => (
          <article class="archive-item">
            <div class="archive-meta mono">
              <span>{formatDate(entry.data.date)}</span>
            </div>
            <div class="archive-body">
              <h3 class="archive-title">
                <a href={`/newsletter/${entry.id}`}>{entry.data.title}</a>
              </h3>
              <p class="archive-sub">{entry.data.subtitle}</p>
              <div class="tag-list" style="margin-top: 0.4rem;">
                {entry.data.topics.map((topic) => (
                  <span class="tag">{topic}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- 구독 -->
  <section class="nl-subscribe" id="newsletter">
    <div class="section-title">
      <h2>Subscribe</h2>
    </div>
    <NewsletterBlock />
  </section>

</BaseLayout>

<style>
  .page-head {
    padding: 1.4rem 0 1.1rem;
    border-top: 2px solid var(--text);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.4rem;
  }

  .page-head h1 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .page-desc {
    font-size: var(--text-sm);
    max-width: 60ch;
    line-height: 1.6;
    margin: 0;
  }

  /* 피처드 발행 */
  .featured-dispatch {
    padding: 1.6rem 1.4rem 1.4rem;
    border-top: 2px solid var(--text);
    background: var(--surface);
    border: 1px solid var(--line-strong);
    display: grid;
    gap: 0.8rem;
  }

  .dispatch-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .featured-badge {
    font-size: 0.6rem;
    background: var(--accent);
    color: var(--accent-text);
    padding: 0.05rem 0.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .dispatch-title {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.18;
    letter-spacing: -0.03em;
  }

  .dispatch-title a {
    text-decoration: none;
  }

  .dispatch-title a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .dispatch-subtitle {
    font-size: var(--text-base);
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .dispatch-summary {
    font-size: var(--text-sm);
    line-height: 1.62;
    margin: 0;
    max-width: 58ch;
  }

  .dispatch-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--line);
  }

  .dispatch-read {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    margin-left: auto;
    white-space: nowrap;
  }

  .dispatch-read:hover {
    color: var(--text);
  }

  /* 아카이브 목록 */
  .archive-list {
    display: grid;
    gap: 0;
  }

  .archive-item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.2rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }

  .archive-meta {
    font-size: var(--text-2xs);
    color: var(--faint);
    letter-spacing: 0.04em;
    padding-top: 0.18rem;
  }

  .archive-title {
    margin: 0 0 0.22rem;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .archive-title a {
    text-decoration: none;
    color: var(--text);
  }

  .archive-title a:hover {
    text-decoration: underline;
    text-underline-offset: 0.16rem;
  }

  .archive-sub {
    font-size: var(--text-sm);
    color: var(--muted);
    margin: 0;
    line-height: 1.52;
  }

  /* 구독 */
  .nl-subscribe {
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .nl-subscribe .section-title {
    padding: 0.7rem 1.2rem 0;
    margin: 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .archive-item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
  }
</style>
