---
import { HUB_NAV, MAIN_NAV, SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : `${SITE.title} | ${SITE.englishName}`;
const currentPath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
const isActiveNav = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="/og-default.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-default.svg" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;500;700&family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">

      <!-- 상단 바: 브랜드 식별자 + 유틸리티 링크 -->
      <div class="topbar">
        <a href="/" class="mono topbar-id" aria-label="홈">thefutureisnowhere</a>
        <nav class="util-nav" aria-label="유틸리티 메뉴">
          <ul>
            {HUB_NAV.map((item) => (
              <li>
                <a
                  class={currentPath.startsWith(item.href) ? 'active' : ''}
                  href={item.href}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- 편집 내비게이션 -->
      <nav class="primary-nav" aria-label="메인 메뉴">
        <ul>
          {MAIN_NAV.map((item) => (
            <li>
              <a
                class={isActiveNav(item.href) ? 'active' : ''}
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <main>
        <slot />
      </main>

      <!-- 푸터: 매거진 콜로폰 -->
      <footer class="footer">
        <div class="footer-inner">
          <div class="footer-brand">
            <p class="mono footer-title">thefutureisnowhere</p>
            <p class="footer-sub muted">{SITE.subtitle}</p>
          </div>
          <nav class="footer-links" aria-label="푸터 메뉴">
            <a href="/interviews">인터뷰</a>
            <a href="/field-notes">현장 노트</a>
            <a href="/interview-proposal">제안하기</a>
            <a href="/about">소개</a>
          </nav>
          <p class="footer-copy muted mono">
            {new Date().getFullYear()}. 모든 글은 현장에서 관찰한 기록입니다.
          </p>
        </div>
      </footer>

    </div>
  </body>
</html>

<style>
  /* ── 상단 바 ─────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.48rem 0;
    border-bottom: 1px solid var(--line);
    font-size: var(--text-2xs);
  }

  .topbar-id {
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
  }

  .topbar-id:hover {
    color: var(--text);
  }

  .util-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.7rem;
    justify-content: flex-end;
  }

  .util-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    text-decoration: none;
  }

  .util-nav a:hover,
  .util-nav a.active {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.16rem;
  }

  /* ── 메인 내비게이션 ────────────────────────── */
  .primary-nav {
    padding: 0.5rem 0 0.55rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0;
  }

  .primary-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.5rem;
  }

  .primary-nav a {
    display: inline-block;
    padding: 0.08rem 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
  }

  .primary-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .primary-nav a.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  /* main 위 간격 */
  main {
    margin-top: 1.5rem;
  }

  /* ── 푸터 ────────────────────────────────── */
  .footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--text);
  }

  .footer-inner {
    display: grid;
    gap: 0.75rem;
  }

  .footer-title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
    margin: 0;
  }

  .footer-sub {
    font-size: var(--text-sm);
    margin: 0;
  }

  .footer-world {
    margin-top: 0.15rem;
  }

  .footer-world .world-main-sm {
    text-align: left;
    font-size: 0.62rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--muted);
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    font-size: var(--text-2xs);
    margin: 0;
  }

  /* ── 반응형 ──────────────────────────────── */
  @media (max-width: 768px) {
    /* 보조 nav 모바일 숨김 — topbar는 thefutureisnowhere만 */
    .util-nav {
      display: none;
    }

    .primary-nav ul {
      gap: 0 1rem;
    }
  }
</style>
